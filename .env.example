# Airtable — server-side only (no VITE_ prefix, never exposed to the browser)
# Get your token at https://airtable.com/create/tokens
# Scopes needed: data.records:read  data.records:write
AIRTABLE_TOKEN=your_airtable_personal_access_token
AIRTABLE_BASE_ID=your_airtable_base_id

# Fonnte — WhatsApp messaging API (server-side only)
# Get your token at fonnte.com after connecting your WhatsApp number
FONNTE_TOKEN=your_fonnte_api_token
